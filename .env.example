# Copy to .env and fill in. .env is gitignored — keys must never be committed.
# Pexels (required): free key at https://www.pexels.com/api/
PEXELS_API_KEY=
# Pixabay (optional 2nd source): free key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=
# Jamendo (optional soundtrack songs/vocals): developer client id from https://devportal.jamendo.com/
JAMENDO_CLIENT_ID=
# Reserved for future OAuth flows; current soundtrack search does not use it.
JAMENDO_CLIENT_SECRET=
# Ollama HTTP endpoint (default; run_with_ollama.sh starts a local server here)
OLLAMA_URL=http://localhost:11434
