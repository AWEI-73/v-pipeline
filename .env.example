# Copy to .env and fill in local values. .env is gitignored; never commit secrets.

# Stock search. Required for Pexels-backed stock sourcing.
PEXELS_API_KEY=

# Optional stock search fallback.
PIXABAY_API_KEY=

# Optional Jamendo soundtrack search credentials.
JAMENDO_CLIENT_ID=
JAMENDO_CLIENT_SECRET=

# Local Ollama HTTP endpoint.
OLLAMA_URL=http://localhost:11434

# Optional executable overrides.
FFMPEG=
FFPROBE=
YTDLP_PATH=

# Optional material/test fixture path used by legacy acceptance helpers.
M6E_FOOTAGE=

# Optional ASR model override for MV/subtitle analysis.
MV_ASR_MODEL=small

# Optional external project workspace root.
VIDEO_PIPELINE_PROJECT_ROOT=

# Optional temp directory and font override for Windows rendering.
VIDEO_PIPELINE_TEMP=
VIDEO_PIPELINE_FONT=

# Optional VoxCPM voiceover provider settings.
VOXCPM_BIN=
VOXCPM_REPO=
VOXCPM_PYTHON=
VOXCPM_MODEL_ID=
