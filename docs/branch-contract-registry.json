        "silent generated-material promotion",
        "BUILD/render from filenames only when visual evidence is required",
        "treating storyboard or motion preview as delivery"
      ],
      "return_to": [
        "main-pipeline",
        "story-structure",
        "workbench-brownfield",
        "verify-delivery"
      ],
      "stages": [
        {
          "stage": "source-review",
          "skill": "skills/material-map.md",
          "artifacts_in": [],
          "artifacts_out": [
            "source_media_review.json"
          ],
          "gate": "material_scan_decision",
          "next_actions_on_pass": [
            "await_material_review"
          ],
          "next_actions_on_fail": [
            "needs-context"
          ]
        },
        {
          "stage": "material-matrix",
          "skill": "skills/curator.md",
          "artifacts_in": [
            "source_media_review.json"
          ],
          "artifacts_out": [
            "material_matrix.json"
          ],
          "gate": "material delta",
          "next_actions_on_pass": [
            "return_to_build"
          ],
          "next_actions_on_fail": [
            "rewrite_or_reshoot_or_waiver",
            "generated_material_fallback"
          ]
        }
      ]
    },
    {
