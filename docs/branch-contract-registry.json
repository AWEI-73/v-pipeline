{
  "artifact_role": "branch_contract_registry",
  "version": 3,
  "status": "mvp_current",
  "purpose": "Machine-readable ownership contracts for Hermes main route and side branches. This registry defines entry conditions, canonical artifacts, stop gates, forbidden writes, and return routes so agents can route work without guessing.",
  "global_rules": [
    "Existing run state wins: inspect tools/pipeline_home.py before writing when a run folder exists.",
    "Whole-video requests enter Stage 0 first; side branches are child lanes unless the request is bounded branch-only work.",
    "Branch outputs are not canonical delivery until the owning gate accepts them.",
    "Workbench, Effect Factory, Soundtrack Arranger, Subtitle/Voiceover, and Verify must not overwrite upstream canonical truth directly.",
    "Delivery readiness is decided by delivery gate evidence, not verify_result.pass alone.",
    "Scripted story human-review closure must use story_human_review_decision.json written by tools/write_story_human_review_decision.py; non-human review does not clear story_human_review_required."
  ],
  "branches": [
    {
      "branch_id": "main-pipeline",
      "name": "Main Video Pipeline",
      "purpose": "Owns Stage 0 route selection, full-video orchestration, BUILD eligibility, delivery promotion, and branch return coordination.",
      "docs": [
        "RUNBOOK.md",
        "docs/pipeline-decision-tree.md",
        "docs/canonical-video-pipeline-route.md",
        "docs/video-pipeline-operating-map.md"
      ],
      "skills": [
        "skills/video-pipeline-route.md",
        "skills/video-intent-planner.md"
      ],
      "entry_conditions": [
        "new or fuzzy whole-video request",
        "existing run resume/inspect request",
        "delivery/export/final candidate request",
        "branch handoff returning to main route"
      ],
      "required_inputs": [
        "project_brief.json or user brief",
        "interaction_log.md when interactive clarification occurred",
        "existing run folder when resuming"
      ],
      "canonical_outputs": [
        "video_intent.json",
        "project_brief.json",
        "interaction_log.md",
        "handoff_packet",
        "segment_contract.json",
        "delivery_requirements.json",
        "final.mp4",
        "final_promotion_report.json"
      ],
      "handoff_outputs": [
        "route_subagent_task.json",
        "route_subagent_result.json",
        "route_orchestrator_state.json"
      ],
      "next_actions": [
        "material-first",
        "structure-first",
        "needs-context",
        "soundtrack-arrange",
        "effect-factory-contract",
        "subtitle-voiceover-handoff",
        "review_workbench_route_back",
        "ready_for_delivery_gate"
      ],
      "stop_gates": [
        "required_followup_questions is non-empty",
        "pipeline_home reports unknown/waiting/repair",
        "branch child contract is required but unresolved",
        "delivery gate blocks"
      ],
      "forbidden_writes": [
        "final.mp4 from Stage 0",
        "route_judgment.json as replacement for video_intent.json",
        "canonical material or timeline rewrites from side branch claims"
      ],
      "return_to": [
        "material-map",
        "soundtrack-arranger",
        "subtitle-voiceover",
        "effect-factory",
        "workbench-brownfield",
        "verify-delivery"
      ],
      "stages": [
        {
          "stage": "stage0-intent-contract",
          "skill": "skills/video-intent-planner.md",
          "artifacts_in": [],
          "artifacts_out": [
            "video_intent.json",
            "edit_decision_plan.json"
          ],
          "gate": "Stage 0",
          "next_actions_on_pass": [
            "material-first",
            "structure-first",
            "needs-context"
          ],
          "next_actions_on_fail": [
            "needs-context"
          ]
        },
        {
          "stage": "contract-compile",
          "skill": "skills/spec-contract.md",
          "artifacts_in": [
            "video_intent.json"
          ],
          "artifacts_out": [
            "segment_contract.json"
          ],
          "gate": "BUILD",
          "next_actions_on_pass": [
            "ready_for_build"
          ],
          "next_actions_on_fail": [
            "revise:spec"
          ]
        },
        {
          "stage": "build-eligibility",
          "skill": "skills/video-pipeline-route.md",
          "artifacts_in": [
            "edit_decision_plan.json",
            "material_matrix.json",
            "audio_decision_plan.json",
            "effect_decision_plan.json",
            "subtitle_voiceover_decision_plan.json"
          ],
          "artifacts_out": [
            "build_handoff.json"
          ],
          "gate": "BUILD",
          "next_actions_on_pass": [
            "ready_for_delivery_gate"
          ],
          "next_actions_on_fail": [
            "return_to_material_map",
            "return_to_soundtrack_arranger",
            "return_to_effect_factory",
            "return_to_subtitle_voiceover"
          ]
        }
      ]
    },
    {
