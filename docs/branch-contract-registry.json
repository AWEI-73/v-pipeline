            "source_media_review.json"
          ],
          "gate": "material_scan_decision",
          "next_actions_on_pass": [
            "await_material_review"
          ],
          "next_actions_on_fail": [
            "needs-context"
          ]
        },
        {
          "stage": "material-matrix",
          "skill": "skills/curator.md",
          "artifacts_in": [
            "source_media_review.json"
          ],
          "artifacts_out": [
            "material_matrix.json"
          ],
          "gate": "material delta",
          "next_actions_on_pass": [
